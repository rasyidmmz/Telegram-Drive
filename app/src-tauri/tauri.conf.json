{
  "$schema": "https://schema.tauri.app/config/2",
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/rasyidmmz/Telegram-Drive/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCMTIwNTI5RUQwMTk4MTMKUldRVG1BSHRLUVVTeTBzQzJvT1V5czBWKzg0UnpESTZvd3U3dndyWWJWa3orOHFIcHhKOWN1SjYK"
    }
  },
  "productName": "Telegram Drive",
  "version": "1.10.0",
  "identifier": "com.cameronamer.telegramdrive",
  "build": {
    "beforeDevCommand": "npm run prepare:mpv && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run prepare:mpv && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Telegram Drive",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http://localhost:* https://asset.localhost http://asset.localhost; media-src 'self' blob: http://localhost:*; img-src 'self' data: blob: asset: https: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' blob: https:; frame-src 'self' blob: https:; worker-src 'self' blob:;",
      "capabilities": [
        "default",
        "mobile-only"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/mpv"],
    "resources": ["binaries/MPV-NOTICE.txt"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
